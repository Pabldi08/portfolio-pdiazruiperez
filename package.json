{
  "scripts": {
    "build": "tailwindcss -i ./css/input.css -o ./css/styles.css --minify && node scripts/cache-bust.mjs",
    "build:css": "npm run build",
    "cache-bust": "node scripts/cache-bust.mjs",
    "start": "serve .",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --watch"
  },
  "devDependencies": {
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.17"
  }
}
